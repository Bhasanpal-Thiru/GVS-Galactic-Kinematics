import pandas as pd
import numpy as np
from scipy.optimize import minimize
import os

# 1. Physics Engine for GVS
def log_dbgr_model(r, alpha, rs, upsilon, v_gas, v_disk, v_bulge):
    v_bar_sq = v_gas**2 + upsilon * v_disk**2 + v_bulge**2
    return np.sqrt(v_bar_sq * (1 + alpha * np.log(1 + r/rs)))

def objective(params, r, v_obs, err_v, v_gas, v_disk, v_bulge):
    alpha, rs, upsilon = params
    v_mod = log_dbgr_model(r, alpha, rs, upsilon, v_gas, v_disk, v_bulge)
    return np.sum(((v_obs - v_mod)/err_v)**2)

# 2. Settings
metadata_file = "SPARC_Lelli2016c.mrt.txt"
data_dir = "SPARC_Data"
G = 4.3009e-6
results = []

# 3. Read and Process
print("Processing 175 Galaxies for Master CSV (Robust Mode)...")
with open(metadata_file, 'r') as f:
    lines = f.readlines()

# Find the start of the data
start_idx = 0
for i, line in enumerate(lines):
    if line.startswith('---'):
        start_idx = i + 1
        break

for line in lines[start_idx:]:
    parts = line.split()
    if len(parts) < 14: continue
    
    try:
        # We target specific galaxy names and their known column offsets
        name = parts[0]
        # Based on the MRT format: Vflat is typically index 5, L3.6 index 7, Rd index 9, MHI index 13
        v_flat = float(parts[5])
        l_36   = float(parts[7])
        r_d    = float(parts[9])
        m_hi   = float(parts[13])
        
        # Calculate Baryonic Mass: M_bar = (Upsilon * L_3.6) + (1.33 * M_HI)
        # Using 0.5 for Disk Upsilon and 1.33 for Helium correction
        m_bar = ((0.5 * l_36) + (1.33 * m_hi)) * 1e9 
        
        fpath = os.path.join(data_dir, f"{name}_rotmod.dat")
        if os.path.exists(fpath) and v_flat > 0 and r_d > 0:
            d = np.loadtxt(fpath, comments='#')
            r, v_obs, err_v, v_gas, v_disk, v_bulge = d[:,0], d[:,1], d[:,2], d[:,3], d[:,4], d[:,5]
            
            # Newtonian Max Velocity for Chi_Baryon (Purely Baryonic)
            v_n_max = np.max(np.sqrt(v_gas**2 + 0.5*v_disk**2 + v_bulge**2))
            
            # Perform MCMC-Equivalent Fit
            res = minimize(objective, [1.0, 1.0, 0.5], args=(r, v_obs, err_v, v_gas, v_disk, v_bulge),
                           bounds=[(0, 50), (0.01, 10), (0.1, 1.2)])
            
            if res.success:
                alpha = res.x[0]
                area = 4 * np.pi * (r_d**2)
                # Chi_Baryon = Ratio of Baryonic Kinetic Energy to Binding Energy
                chi_b = (r_d * (v_n_max**2)) / (G * m_bar)
                
                results.append({
                    "Galaxy_ID": name,
                    "R_d_kpc": r_d,
                    "Area_kpc2": area,
                    "Log_Area": np.log10(area),
                    "Chi_Baryon": chi_b,
                    "Alpha_GVS": alpha
                })
    except (ValueError, IndexError):
        continue

# 4. Save Final Evidence
df_master = pd.DataFrame(results)
df_master.to_csv("GVS_Results_Master.csv", index=False)
print(f"SUCCESS: Processed {len(df_master)} galaxies into GVS_Results_Master.csv.")

